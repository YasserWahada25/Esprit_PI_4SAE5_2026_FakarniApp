pipeline {
    agent any

    tools {
        maven 'Maven-3.9'
        jdk 'JDK-21'
    }

    environment {
        SERVICE_NAME    = 'group-service'
        SERVICE_PATH    = 'backend/group'
        DOCKER_IMAGE    = 'didou2505/fakarni-group-service'
        SONAR_KEY       = 'group-service'
        GIT_REPO        = 'https://github.com/YasserWahada25/Esprit_PI_4SAE5_2026_FakarniApp.git'
        GIT_BRANCH      = 'main'
    }

    stages {

        stage('📥 Checkout') {
            steps {
                retry(3) {
                    script {
                        // Configure git for large repos
                        sh '''
                            git config --global http.postBuffer 524288000
                            git config --global http.lowSpeedLimit 0
                            git config --global http.lowSpeedTime 999999
                        '''
                    }
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: "*/${GIT_BRANCH}"]],
                        userRemoteConfigs: [[
                            url: "${GIT_REPO}",
                            credentialsId: 'github-credentials'
                        ]],
                        extensions: [
                            [$class: 'CloneOption', shallow: true, noTags: true, depth: 1, timeout: 30],
                            [$class: 'CheckoutOption', timeout: 30]
                        ]
                    ])
                }
            }
        }

        stage('🔨 Build') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh 'mvn clean compile -DskipTests'
                }
            }
        }

        stage('🧪 Test') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    dir("${SERVICE_PATH}") {
                        junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml'
                        jacoco execPattern: '**/target/jacoco.exec',
                               classPattern: '**/target/classes',
                               sourcePattern: '**/src/main/java'
                    }
                }
            }
        }

        stage('📊 SonarQube') {
            steps {
                script {
                    try {
                        dir("${SERVICE_PATH}") {
                            withSonarQubeEnv('SonarQube') {
                                sh """
                                    mvn sonar:sonar \
                                        -Dsonar.projectKey=${SONAR_KEY} \
                                        -Dsonar.projectName=${SERVICE_NAME} \
                                        -Dsonar.java.binaries=target/classes \
                                        -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                                """
                            }
                        }
                    } catch (Exception e) {
                        echo "⚠️ SonarQube analysis failed: ${e.message}"
                        echo "Continuing pipeline without SonarQube analysis..."
                    }
                }
            }
        }

        stage('📦 Package') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh 'mvn package -DskipTests'
                }
            }
        }

        stage('🐳 Docker Build') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh """
                        docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} .
                        docker tag  ${DOCKER_IMAGE}:${BUILD_NUMBER} ${DOCKER_IMAGE}:latest
                    """
                }
            }
        }

        stage('📤 Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_TOKEN'
                )]) {
                    sh """
                        echo "\$DOCKER_TOKEN" | docker login -u "\$DOCKER_USER" --password-stdin
                        docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                        docker push ${DOCKER_IMAGE}:latest
                        docker logout
                    """
                }
            }
        }

        stage('🚀 Trigger CD') {
            steps {
                script {
                    try {
                        build job: "${SERVICE_NAME}-CD",
                              parameters: [string(name: 'IMAGE_TAG', value: "${BUILD_NUMBER}")],
                              wait: false
                    } catch (Exception e) {
                        echo "⚠️ CD job '${SERVICE_NAME}-CD' not found yet — skipping."
                    }
                }
            }
        }
    }

    post {
        success { echo "✅ CI SUCCESS — ${SERVICE_NAME}:${BUILD_NUMBER}" }
        failure { echo "❌ CI FAILED  — ${SERVICE_NAME}:${BUILD_NUMBER}" }
        always  { deleteDir() }
    }
}
