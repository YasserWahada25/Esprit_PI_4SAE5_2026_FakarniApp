# ==========================================
# VARIABLES D'ENVIRONNEMENT - FAKARNI
# ==========================================
# Copier ce fichier en .env et remplir avec vos vraies valeurs

# ==========================================
# MAIL CONFIGURATION
# ==========================================

# User Service - Gmail SMTP
# Pour générer un mot de passe d'application Gmail :
# 1. Aller sur https://myaccount.google.com/security
# 2. Activer la validation en 2 étapes
# 3. Générer un mot de passe d'application
MAIL_USERNAME_USER=votre-email@gmail.com
MAIL_PASSWORD_USER=votre-mot-de-passe-app-gmail

# Geofencing Service - Gmail SMTP
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-mot-de-passe-app-gmail

# Event Service - Mailtrap (pour tests)
# Créer un compte sur https://mailtrap.io
MAILTRAP_USERNAME=votre-mailtrap-username
MAILTRAP_PASSWORD=votre-mailtrap-password

# ==========================================
# OAUTH2 CONFIGURATION
# ==========================================

# Google OAuth2
# Créer un projet sur https://console.cloud.google.com
# Activer Google+ API
# Créer des identifiants OAuth 2.0
GOOGLE_CLIENT_ID=votre-google-client-id.apps.googleusercontent.com

# Facebook OAuth2
# Créer une app sur https://developers.facebook.com
FACEBOOK_APP_ID=votre-facebook-app-id
FACEBOOK_APP_SECRET=votre-facebook-app-secret

# ==========================================
# TWILIO CONFIGURATION (SMS)
# ==========================================

# Geofencing Service - Twilio SMS
# Créer un compte sur https://www.twilio.com
TWILIO_ACCOUNT_SID=votre-twilio-account-sid
TWILIO_AUTH_TOKEN=votre-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# MySQL Root Password (utilisé par tous les services MySQL)
MYSQL_ROOT_PASSWORD=root

# MongoDB Credentials
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin

# ==========================================
# SECURITY CONFIGURATION
# ==========================================

# JWT Secret (partagé entre Gateway et tous les services)
# Générer avec : echo -n "votre-secret-tres-long" | base64
JWT_SECRET=ZHVtbXktc2VjcmV0LXNlY3JldC1zZWNyZXQtc2VjcmV0LXNlY3JldC1zZWNyZXQ=

# ==========================================
# NOTES
# ==========================================

# Variables OBLIGATOIRES pour le fonctionnement minimal :
# - MAIL_USERNAME_USER
# - MAIL_PASSWORD_USER

# Variables OPTIONNELLES (pour fonctionnalités avancées) :
# - GOOGLE_CLIENT_ID (connexion Google)
# - FACEBOOK_APP_ID / FACEBOOK_APP_SECRET (connexion Facebook)
# - TWILIO_* (notifications SMS)
# - MAILTRAP_* (tests d'emails)

# Pour tester rapidement sans configurer toutes les variables :
# 1. Remplir uniquement MAIL_USERNAME_USER et MAIL_PASSWORD_USER
# 2. Laisser les autres variables vides
# 3. Les fonctionnalités correspondantes seront désactivées

# ==========================================
# ENVIRONNEMENTS
# ==========================================

# Development (local)
NODE_ENV=development

# Production
# NODE_ENV=production
