pipeline {
    agent any

    tools {
        nodejs 'NodeJS-20'
    }

    environment {
        SERVICE_NAME    = 'frontend'
        SERVICE_PATH    = 'frontend'
        DOCKER_IMAGE    = 'didou2505/fakarni-frontend'
        SONAR_KEY       = 'fakarni-frontend'
        GIT_REPO        = 'https://github.com/YasserWahada25/Esprit_PI_4SAE5_2026_FakarniApp.git'
        GIT_BRANCH      = 'main'
    }

    stages {

        stage('📥 Checkout') {
            steps {
                git branch: "${GIT_BRANCH}",
                    credentialsId: 'github-credentials',
                    url: "${GIT_REPO}"
            }
        }

        stage('📦 Install Dependencies') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh 'npm ci'
                }
            }
        }

        stage('🧪 Test') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh 'npm run test -- --watch=false --browsers=ChromeHeadless --code-coverage || true'
                }
            }
        }

        stage('📊 SonarQube') {
            steps {
                dir("${SERVICE_PATH}") {
                    withSonarQubeEnv('SonarQube') {
                        sh """
                            npx sonar-scanner \
                                -Dsonar.projectKey=${SONAR_KEY} \
                                -Dsonar.projectName=${SERVICE_NAME} \
                                -Dsonar.sources=src \
                                -Dsonar.exclusions=**/node_modules/**,**/dist/**,**/*.spec.ts \
                                -Dsonar.typescript.lcov.reportPaths=coverage/lcov.info
                        """
                    }
                }
            }
        }

        stage('🏗️ Build') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh 'npm run build -- --configuration=production'
                }
            }
        }

        stage('🐳 Docker Build') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh """
                        docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} .
                        docker tag  ${DOCKER_IMAGE}:${BUILD_NUMBER} ${DOCKER_IMAGE}:latest
                    """
                }
            }
        }

        stage('📤 Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_TOKEN'
                )]) {
                    sh """
                        echo "\$DOCKER_TOKEN" | docker login -u "\$DOCKER_USER" --password-stdin
                        docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                        docker push ${DOCKER_IMAGE}:latest
                        docker logout
                    """
                }
            }
        }

        stage('🚀 Trigger CD') {
            steps {
                script {
                    try {
                        build job: "${SERVICE_NAME}-CD",
                              parameters: [string(name: 'IMAGE_TAG', value: "${BUILD_NUMBER}")],
                              wait: false
                    } catch (Exception e) {
                        echo "⚠️ CD job '${SERVICE_NAME}-CD' not found yet — skipping."
                    }
                }
            }
        }
    }

    post {
        success { echo "✅ CI SUCCESS — ${SERVICE_NAME}:${BUILD_NUMBER}" }
        failure { echo "❌ CI FAILED  — ${SERVICE_NAME}:${BUILD_NUMBER}" }
        always  { cleanWs() }
    }
}
