pipeline {
    agent any

    environment {
        SERVICE_NAME    = 'detection-alzheimer'
        SERVICE_PATH    = 'detection-alzheimer/detection-alzheimer'
        DOCKER_IMAGE    = 'didou2505/fakarni-detection-alzheimer'
        SONAR_KEY       = 'fakarni-detection-alzheimer'
        GIT_REPO        = 'https://github.com/YasserWahada25/Esprit_PI_4SAE5_2026_FakarniApp.git'
        GIT_BRANCH      = 'main'
    }

    stages {

        stage('📥 Checkout') {
            steps {
                git branch: "${GIT_BRANCH}",
                    credentialsId: 'github-credentials',
                    url: "${GIT_REPO}"
            }
        }

        stage('🐍 Setup Python') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh '''
                        python3 -m venv venv
                        . venv/bin/activate
                        pip install --upgrade pip
                        pip install -r requirements.txt
                        pip install pytest pytest-cov
                    '''
                }
            }
        }

        stage('🧪 Test') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh '''
                        . venv/bin/activate
                        pytest test_api.py -v --cov=. --cov-report=xml:coverage.xml || true
                    '''
                }
            }
        }

        stage('📊 SonarQube') {
            steps {
                dir("${SERVICE_PATH}") {
                    withSonarQubeEnv('SonarQube') {
                        sh """
                            npx sonar-scanner \
                                -Dsonar.projectKey=${SONAR_KEY} \
                                -Dsonar.projectName=${SERVICE_NAME} \
                                -Dsonar.sources=. \
                                -Dsonar.language=py \
                                -Dsonar.python.version=3 \
                                -Dsonar.python.coverage.reportPaths=coverage.xml \
                                -Dsonar.exclusions=**/venv/**,**/__pycache__/**,**/alzheimer_final_v3/**
                        """
                    }
                }
            }
        }

        stage('🐳 Docker Build') {
            steps {
                dir("${SERVICE_PATH}") {
                    sh """
                        docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} .
                        docker tag  ${DOCKER_IMAGE}:${BUILD_NUMBER} ${DOCKER_IMAGE}:latest
                    """
                }
            }
        }

        stage('📤 Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_TOKEN'
                )]) {
                    sh """
                        echo "\$DOCKER_TOKEN" | docker login -u "\$DOCKER_USER" --password-stdin
                        docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                        docker push ${DOCKER_IMAGE}:latest
                        docker logout
                    """
                }
            }
        }

        stage('🚀 Trigger CD') {
            steps {
                script {
                    try {
                        build job: "${SERVICE_NAME}-CD",
                              parameters: [string(name: 'IMAGE_TAG', value: "${BUILD_NUMBER}")],
                              wait: false
                    } catch (Exception e) {
                        echo "⚠️ CD job '${SERVICE_NAME}-CD' not found yet — skipping."
                    }
                }
            }
        }
    }

    post {
        success { echo "✅ CI SUCCESS — ${SERVICE_NAME}:${BUILD_NUMBER}" }
        failure { echo "❌ CI FAILED  — ${SERVICE_NAME}:${BUILD_NUMBER}" }
        always  { cleanWs() }
    }
}
